# ---------------------------------------------------------------------------
# ONDEWO SURVEY Python client SDK — example configuration template.
#
# This is a NON-SECRET template. Copy the real values in locally, but never
# commit real credentials. Every variable the examples under examples/ read is
# listed here with the ONE canonical name for that concept.
# ---------------------------------------------------------------------------

# --- Connection ------------------------------------------------------------
ONDEWO_HOST=localhost
ONDEWO_PORT=50051

# --- Secure channel --------------------------------------------------------
# ONDEWO_USE_SECURE_CHANNEL: "true" for a TLS gRPC channel, "false" for plaintext.
ONDEWO_USE_SECURE_CHANNEL=false
# ONDEWO_GRPC_CERT: optional path to a PEM cert file for the secure channel.
ONDEWO_GRPC_CERT=

# --- Keycloak (headless offline-token / ROPC auth) -------------------------
KEYCLOAK_URL=https://my-host/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-survey-cai-sdk-public
# Public SDK client has no secret; leave blank unless your realm requires one.
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# KEYCLOAK_VERIFY_SSL: "true" to verify the Keycloak TLS cert, "false" for self-signed/local.
KEYCLOAK_VERIFY_SSL=true
